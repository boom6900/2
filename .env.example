# ═══════════════════════════════════════════════════
#  .env.example — أسماء متغيرات البيئة
#  انسخ هذا الملف إلى .env واملأ القيم الحقيقية
# ═══════════════════════════════════════════════════

# Alpaca API Keys (من alpaca.markets)
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# للتداول التجريبي (Paper Trading):
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# للتداول الحقيقي (Live Trading) — استخدم بحذر:
# ALPACA_BASE_URL=https://api.alpaca.markets
